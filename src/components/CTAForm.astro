---
interface Props {
  heading?: string;
  id?: string;
}
const { heading = 'Primește demo în 24h', id = 'demo' } = Astro.props;
---

<section id={id} class="bg-brand py-16 px-4">
  <div class="max-w-xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">{heading}</h2>
    <p class="text-white/80 mb-2">
      Completează formularul și echipa noastră te va contacta în mai puțin de 24 de ore.
    </p>
    <p class="text-accent font-semibold mb-8">
      Folosit de peste 2.300 de restaurante din România
    </p>
    <form
      name="demo-request"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      action="https://formsubmit.co/contact@horecaorders.com"
      class="flex flex-col gap-4"
      id="cta-form"
    >
      <input type="hidden" name="form-name" value="demo-request" />
      <input type="hidden" name="bot-field" />
      <input type="hidden" name="_subject" value="Demo request de pe horecaorders.com" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_next" value="https://horecaorders.com/?demo=multumim" />
      <input type="hidden" name="utm_source" />
      <input type="hidden" name="utm_medium" />
      <input type="hidden" name="utm_campaign" />
      <input type="hidden" name="utm_term" />
      <input type="hidden" name="utm_content" />
      <input type="hidden" name="landing_page" />
      <input
        type="text"
        name="name"
        placeholder="Numele tău"
        required
        class="w-full px-4 py-3 rounded-lg text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-accent"
      />
      <input
        type="tel"
        name="phone"
        placeholder="Număr de telefon"
        required
        class="w-full px-4 py-3 rounded-lg text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-accent"
      />
      <input
        type="email"
        name="email"
        placeholder="Email"
        required
        class="w-full px-4 py-3 rounded-lg text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-accent"
      />
      <select
        name="type"
        class="w-full px-4 py-3 rounded-lg text-gray-900 focus:outline-none focus:ring-2 focus:ring-accent"
      >
        <option value="restaurant">Sunt Restaurant / Hotel / Catering</option>
        <option value="furnizor">Sunt Furnizor</option>
      </select>
      <button
        type="submit"
        class="bg-accent text-gray-900 font-bold py-3 px-8 rounded-full text-lg hover:bg-yellow-400 transition mt-2"
      >
        Primește demo în 24h
      </button>
      <p class="text-white/60 text-sm mt-3">Fără card. Configurare în mai puțin de 24h.</p>
    </form>
  </div>
</section>

<script is:inline>
  // Populate UTM fields from URL params and sessionStorage
  (function() {
    var params = new URLSearchParams(window.location.search);
    var utmKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];

    // Store UTM params in sessionStorage on first visit
    utmKeys.forEach(function(key) {
      var val = params.get(key);
      if (val) sessionStorage.setItem(key, val);
    });

    // Populate hidden fields from sessionStorage (persists across page navigations)
    document.querySelectorAll('#cta-form').forEach(function(form) {
      utmKeys.forEach(function(key) {
        var field = form.querySelector('input[name="' + key + '"]');
        if (field) field.value = sessionStorage.getItem(key) || '';
      });
      var landingField = form.querySelector('input[name="landing_page"]');
      if (landingField) {
        landingField.value = sessionStorage.getItem('landing_page') || window.location.pathname;
        if (!sessionStorage.getItem('landing_page')) {
          sessionStorage.setItem('landing_page', window.location.pathname);
        }
      }
    });

    // Track form submission in GA4
    document.querySelectorAll('#cta-form').forEach(function(form) {
      form.addEventListener('submit', function() {
        if (typeof gtag === 'function') {
          gtag('event', 'generate_lead', {
            event_category: 'engagement',
            event_label: form.querySelector('select[name="type"]').value,
            value: 1
          });
        }
      });
    });
  })();
</script>
