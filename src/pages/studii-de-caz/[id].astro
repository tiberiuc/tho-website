---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const studies = await getCollection('case-studies');
  return studies
    .filter((s) => !s.data.draft)
    .map((s) => ({ params: { id: s.id }, props: { study: s } }));
}

const { study } = Astro.props;
const { Content } = await render(study);

function formatDate(date: Date) {
  return date.toLocaleDateString('ro-RO', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const canonicalURL = `/studii-de-caz/${study.id}`;
---

<Base title={`${study.data.title} | HORECA ORDERS`} description={study.data.description} canonicalPath={canonicalURL}>
  <Header slot="header" current="studii-de-caz" />

  <article class="py-12 md:py-16">
    <div class="max-w-3xl mx-auto px-4">
      <div class="mb-8">
        <a href="/studii-de-caz" class="text-brand text-sm font-semibold hover:underline">&larr; Înapoi la studii de caz</a>
      </div>

      <header class="mb-10">
        <div class="flex items-center gap-3 text-sm text-gray-500 mb-4">
          <span class="bg-brand/10 text-brand px-3 py-1 rounded-full font-semibold">{study.data.industry}</span>
          <time datetime={study.data.date.toISOString()}>{formatDate(study.data.date)}</time>
        </div>
        <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4">{study.data.title}</h1>
        <p class="text-lg text-gray-600">Client: <strong>{study.data.client}</strong></p>
      </header>

      <div class="prose prose-lg max-w-none prose-headings:text-gray-900 prose-a:text-brand prose-a:no-underline hover:prose-a:underline prose-img:rounded-xl prose-table:text-sm">
        <Content />
      </div>

      <div class="mt-16 pt-8 border-t border-gray-200">
        <div class="bg-grey-bg rounded-xl p-8 text-center">
          <h3 class="text-xl font-bold text-gray-900 mb-2">Vrei rezultate similare?</h3>
          <p class="text-gray-600 mb-6">Începe gratuit și vezi cum HORECA ORDERS îți transformă comenzile.</p>
          <a href="/preturi" class="inline-block bg-accent text-gray-900 font-bold px-8 py-3 rounded-full hover:bg-yellow-400 transition">
            Începe gratuit
          </a>
        </div>
      </div>
    </div>
  </article>

  <Footer slot="footer" />
</Base>
