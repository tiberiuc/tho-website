---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTAForm from '../components/CTAForm.astro';
---

<Base
  title="Cum funcționează HORECA ORDERS — Platformă de comenzi B2B"
  description="Descoperă cum funcționează HORECA ORDERS: alegi produsele, finalizezi comanda, furnizorul primește instant. Simplu, rapid, fără erori."
  canonicalPath="/cum-functioneaza"
>
  <Header slot="header" current="cum-functioneaza" />

  <!-- Hero -->
  <section class="bg-brand text-white py-16 md:py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-6xl font-extrabold italic">CUM FUNCȚIONEAZĂ</h1>
      <p class="mt-4 text-lg text-white/80 max-w-2xl mx-auto">
        Trei pași simpli pentru a digitaliza comenzile restaurantului tău.
      </p>
    </div>
  </section>

  <!-- Steps -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="space-y-20">
        <!-- Step 1 -->
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div>
            <div class="flex items-center gap-4 mb-4">
              <span class="bg-accent text-gray-900 w-12 h-12 rounded-full flex items-center justify-center font-bold text-xl">1</span>
              <h2 class="text-2xl font-bold">Alegi produsele</h2>
            </div>
            <p class="text-gray-600 text-lg">
              Deschizi aplicația, alegi furnizorul și selectezi produsele din lista ta personalizată.
              Fiecare produs are codul unic, unitatea de măsură și prețul aferent.
            </p>
          </div>
          <div class="flex justify-center">
            <img
              src="/images/i-phone-x-mockup.png"
              srcset="/images/i-phone-x-mockup.png 1x, /images/i-phone-x-mockup@2x.png 2x"
              alt="Selectarea produselor în aplicația HORECA ORDERS"
              class="h-80 object-contain"
              width="240"
              height="320"
              loading="lazy"
            />
          </div>
        </div>

        <!-- Step 2 -->
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="order-2 md:order-1 flex justify-center">
            <img
              src="/images/finalizeaza-datele-comenzii.png"
              srcset="/images/finalizeaza-datele-comenzii.png 1x, /images/finalizeaza-datele-comenzii@2x.png 2x"
              alt="Finalizarea detaliilor comenzii"
              class="h-80 object-contain"
              width="240"
              height="320"
              loading="lazy"
            />
          </div>
          <div class="order-1 md:order-2">
            <div class="flex items-center gap-4 mb-4">
              <span class="bg-accent text-gray-900 w-12 h-12 rounded-full flex items-center justify-center font-bold text-xl">2</span>
              <h2 class="text-2xl font-bold">Finalizezi comanda</h2>
            </div>
            <p class="text-gray-600 text-lg">
              Alegi data de livrare, metoda de plată și adaugi comentarii dacă este nevoie.
              Apoi trimiți comanda cu un singur click.
            </p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div>
            <div class="flex items-center gap-4 mb-4">
              <span class="bg-accent text-gray-900 w-12 h-12 rounded-full flex items-center justify-center font-bold text-xl">3</span>
              <h2 class="text-2xl font-bold">Furnizorul primește comanda</h2>
            </div>
            <p class="text-gray-600 text-lg">
              Furnizorul primește comanda instant prin aplicație, email sau SMS.
              Confirmă livrarea, iar tu primești notificarea. Gata!
            </p>
          </div>
          <div class="flex justify-center">
            <img
              src="/images/comanda-trimisa-img.png"
              srcset="/images/comanda-trimisa-img.png 1x, /images/comanda-trimisa-img@2x.png 2x"
              alt="Comanda trimisă cu succes"
              class="h-80 object-contain"
              width="240"
              height="320"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Post-steps CTA -->
  <section class="bg-accent py-8 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <a href="#demo" class="text-gray-900 font-bold text-xl hover:underline">
        Ești gata? Creează cont gratuit &rarr;
      </a>
    </div>
  </section>

  <!-- Benefits -->
  <section class="bg-grey-bg py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-2xl md:text-3xl font-extrabold text-brand mb-10">De ce HORECA ORDERS?</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <img src="/images/adio-greseli.png" alt="Fără greșeli" class="w-24 h-24 mx-auto" width="96" height="96" loading="lazy" />
          <h3 class="font-bold text-lg mt-4">Spune adio greșelilor</h3>
          <p class="text-gray-600 mt-2">Comenzile au mereu codul unic al produselor, unitatea de măsură și confirmarea livrării. Reduceți greșelile cu 85%.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <img src="/images/castiga-timp.png" alt="Economisești timp" class="w-24 h-24 mx-auto" width="96" height="96" loading="lazy" />
          <h3 class="font-bold text-lg mt-4">Câștigă timp</h3>
          <p class="text-gray-600 mt-2">Plasați rapid toate comenzile dintr-o singură aplicație. Câștigați peste 4 ore pe săptămână.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <img src="/images/suport-rapid.png" alt="Suport rapid" class="w-24 h-24 mx-auto" width="96" height="96" loading="lazy" />
          <h3 class="font-bold text-lg mt-4">Suport rapid</h3>
          <p class="text-gray-600 mt-2">Discutați cu echipa HORECA ORDERS în aplicație. Vă configurăm în mai puțin de 24 de ore.</p>
        </div>
      </div>
    </div>
  </section>

  <CTAForm />

  <Footer slot="footer" />
</Base>
